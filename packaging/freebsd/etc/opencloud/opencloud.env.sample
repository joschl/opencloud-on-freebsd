# OpenCloud base runtime configuration for FreeBSD.
# Copy to /usr/local/etc/opencloud/opencloud.env and edit before first start.

OC_URL=https://cloud.example.com
OC_LOG_LEVEL=info
OC_LOG_COLOR=false
OC_LOG_PRETTY=false

# TLS is expected to terminate at an external reverse proxy.
PROXY_TLS=false
OC_INSECURE=false
PROXY_ENABLE_BASIC_AUTH=false

# Demo users must stay disabled for production use.
IDM_CREATE_DEMO_USERS=false

# Required before the first start when using the built-in IDM.
# Changes after first initialization are ignored by OpenCloud.
IDM_ADMIN_PASSWORD=change-me-before-first-start

PROXY_CSP_CONFIG_FILE_LOCATION=/usr/local/etc/opencloud/csp.yaml
OC_PASSWORD_POLICY_BANNED_PASSWORDS_LIST=/usr/local/etc/opencloud/banned-password-list.txt
OC_CONFIG_DIR=/usr/local/etc/opencloud
OC_DATA_DIR=/var/db/opencloud
HOME=/var/db/opencloud

FRONTEND_ARCHIVER_MAX_SIZE=10000000000
FRONTEND_CHECK_FOR_UPDATES=true
OC_SHARING_PUBLIC_SHARE_MUST_HAVE_PASSWORD=true
OC_SHARING_PUBLIC_WRITEABLE_SHARE_MUST_HAVE_PASSWORD=false
OC_PASSWORD_POLICY_DISABLED=false
OC_PASSWORD_POLICY_MIN_CHARACTERS=8
OC_PASSWORD_POLICY_MIN_LOWERCASE_CHARACTERS=1
OC_PASSWORD_POLICY_MIN_UPPERCASE_CHARACTERS=1
OC_PASSWORD_POLICY_MIN_DIGITS=1
OC_PASSWORD_POLICY_MIN_SPECIAL_CHARACTERS=1
